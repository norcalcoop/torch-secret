DATABASE_URL=postgresql://user:password@localhost:5432/secureshare
PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# Force HTTPS redirect (set true behind TLS-terminating reverse proxy)
# FORCE_HTTPS=true

# Optional: Redis URL for distributed rate limiting (multi-instance deployments)
# REDIS_URL=redis://localhost:6379

# === Authentication (Phase 22) ===
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=your-32-byte-hex-secret-here
BETTER_AUTH_URL=http://localhost:3000
# Frontend origin for email links. Set to the Vite dev server port in development
# so reset/verify links land on :5173, not Express (:3000). In production, omit or
# match BETTER_AUTH_URL (same domain).
APP_URL=http://localhost:5173

# Google OAuth (optional — comment out to disable Google sign-in)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional — comment out to disable GitHub sign-in)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Email delivery via Resend
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=SecureShare <noreply@yourdomain.com>
