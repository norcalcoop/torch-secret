DATABASE_URL=postgresql://user:password@localhost:5432/secureshare
PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# Force HTTPS redirect (set true behind TLS-terminating reverse proxy)
# FORCE_HTTPS=true

# Optional: Redis URL for distributed rate limiting (multi-instance deployments)
# REDIS_URL=redis://localhost:6379

# === Authentication (Phase 22) ===
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=your-32-byte-hex-secret-here
BETTER_AUTH_URL=http://localhost:3000
# Base URL for the application (used in OAuth callbacks and email links).
# Production: https://torchsecret.com
# Local dev override: http://localhost:5173 (Vite dev server)
# Set to the Vite dev server port in development so reset/verify links land on :5173, not Express (:3000).
APP_URL=http://localhost:5173

# Google OAuth (optional — comment out to disable Google sign-in)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional — comment out to disable GitHub sign-in)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Email delivery via Resend
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Torch Secret <noreply@torchsecret.com>

# === Analytics (Phase 25) ===
# PostHog project API key — obtain from posthog.com (Settings > Project API Keys)
# Leave unset in local dev to skip analytics initialization entirely (safe default)
# VITE_POSTHOG_KEY=phc_your_key_here
# PostHog API host — defaults to US cloud if unset
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# === Stripe Billing (Phase 34) ===
# Stripe secret key — use sk_test_... for local development, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_your_key_here
# Webhook signing secret — use `stripe listen` CLI value locally, Dashboard webhook secret in production
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
# Price ID for the Pro monthly subscription — create in Stripe Dashboard -> Products
STRIPE_PRO_PRICE_ID=price_your_price_id_here

# Email Capture (Phase 36)
# Resend Audience ID — obtain from Resend Dashboard -> Audiences
RESEND_AUDIENCE_ID=aud_test_placeholder
# Salt for SHA-256 IP hashing — generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
IP_HASH_SALT=test-salt-min-16-chars
